{
  "name": "design-system",
  "version": "0.23.9",
  "description": "A comprehensive design system built with React, TypeScript, and styled-components",
  "keywords": [
    "design-system",
    "react",
    "typescript",
    "ui-components",
    "styled-components"
  ],
  "private": false,
  "author": "jung-inhwa",
  "license": "MIT",
  "homepage": "https://github.com/2najung/design-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2najung/design-system.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      }
    },
    "./styles/*": {
      "development": "./src/styles/*",
      "default": "./dist/styles/*"
    },
    "./assets/*": "./src/assets/*"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:icons && vite build && npm run copy:styles",
    "preview": "vite preview",
    "lint": "eslint .",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "copy:styles": "cp -r src/styles dist/styles",
    "lib:build": "npm run generate:icons && vite build && npm run copy:styles",
    "lib:watch": "vite build --watch",
    "lib:clean": "rm -rf dist",
    "lib:prepare": "npm run lib:clean && npm run lib:build",
    "prepublishOnly": "npm run lib:prepare",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:deploy": "npm run storybook:build && gh-pages -d storybook-static"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "styled-components": ">=6.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.0",
    "@storybook/addon-a11y": "^9.0.8",
    "@storybook/addon-docs": "^9.0.8",
    "@storybook/addon-onboarding": "^9.0.8",
    "@storybook/addon-vitest": "^9.0.8",
    "@storybook/react": "^9.1.17",
    "@storybook/react-vite": "^9.0.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^3.2.3",
    "@vitest/coverage-v8": "^3.2.3",
    "autoprefixer": "^10.4.21",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^9.0.8",
    "typescript-eslint": "^8.18.0",
    "gh-pages": "^6.3.0",
    "playwright": "^1.53.0",
    "postcss": "^8.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.0.8",
    "styled-components": "^6.1.19",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.3"
  }
}
